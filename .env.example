# Salin ke .env.local — jangan commit rahasia produksi
#
# WAJIB untuk production:
#   NEXTAUTH_URL  — URL production (mis. https://mb178.online)
#   NEXTAUTH_SECRET — generate: openssl rand -base64 32
#
# WAJIB untuk fitur database (login, produk, pesanan):
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY

# Saat npm run dev, NEXTAUTH_URL harus http://localhost:3000 (bukan domain production).
NEXTAUTH_URL=http://localhost:3000
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Supabase — isi dari Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox Dark Mode — pengaturan toko / peta (token publik dari dashboard Mapbox)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=