# Salin ke .env.local — jangan commit rahasia produksi
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Supabase (opsional — tanpa ini aplikasi memakai mock data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: salin dari Vercel / Supabase (Settings → API) — untuk API owner & upload ke bucket
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox Dark Mode — pengaturan toko / peta (token publik dari dashboard Mapbox)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=